# =========================
# Docker / Compose
# =========================
COMPOSE_PROJECT_NAME=capacity

# Puertos publicados en tu máquina local
FRONTEND_PORT=8080
FRONTEND_DEV_PORT=5173
BACKEND_PORT=3002
DB_PUBLIC_PORT=14333

# =========================
# SQL Server (contenedor db)
# =========================
# Debe cumplir complejidad de SQL Server:
# mínimo 8 caracteres, mayúscula, minúscula, número y símbolo.
MSSQL_SA_PASSWORD=ChangeThis_StrongPass123!
MSSQL_PID=Developer

# =========================
# Base de datos usada por backend/db-init
# =========================
DB_CLIENT=sqlserver
DB_HOST=db
DB_PORT=1433
DB_NAME=capacity
DB_USER=sa
DB_PASSWORD=ChangeThis_StrongPass123!
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_ENCRYPT=true
DB_TRUST_CERT=true
DB_SCHEMA=dbo

# =========================
# Backend (Node/Express)
# =========================
NODE_ENV=production
PORT=3002
JWT_SECRET=ChangeThis_ToALongRandomSecret_ForProd
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:8080,http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_DEV_MAX=1000
RATE_LIMIT_AUTH_MAX=10
BCRYPT_ROUNDS=12

# URLs públicas esperadas
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:3002

# =========================
# Frontend (Vite build)
# =========================
# Se inyectan en build del contenedor frontend
VITE_API_URL=http://localhost:3002/api
VITE_API_FALLBACK_URLS=http://localhost:3001/api,http://localhost:3003/api,http://localhost:3004/api,http://localhost:3005/api,http://localhost:3006/api,http://localhost:3007/api,http://localhost:3008/api,http://localhost:3009/api,http://localhost:3010/api,http://localhost:3011/api
VITE_API_URL_DEV=http://localhost:3002/api

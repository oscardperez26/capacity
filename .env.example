# =============================================================
# Copia este archivo a .env y rellena los valores reales
# cp .env.example .env
# =============================================================

# ── Docker Compose ────────────────────────────────────────────
COMPOSE_PROJECT_NAME=capacity

# Puerto público del frontend (acceso desde el navegador)
FRONTEND_PORT=8080

# ── SQL Server (instalado en el servidor, NO en Docker) ───────
# DB_HOST: IP o hostname del servidor donde está SQL Server
# - En Linux: host.docker.internal  (Docker ya lo resuelve al host)
# - En Windows Server: la IP real del servidor, ej: 192.168.1.100
DB_HOST=host.docker.internal
DB_PORT=1433
DB_NAME=capacity
DB_USER=sa
DB_PASSWORD=TuPasswordAqui
DB_POOL_MIN=0
DB_POOL_MAX=10
DB_ENCRYPT=true
# Cambiar a false si SQL Server tiene certificado TLS firmado
DB_TRUST_CERT=true

# ── Backend ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3002

# OBLIGATORIO: mínimo 32 caracteres aleatorios
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ChangeThis_ToALongRandomSecret_MinLength32

JWT_EXPIRES_IN=8h

# URL del frontend en producción (para CORS)
# Ejemplo: http://192.168.1.100:8080  o  https://capacity.tuempresa.com
CORS_ORIGIN=http://localhost:8080

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
BCRYPT_ROUNDS=12

# ── Frontend (Vite build) ─────────────────────────────────────
# Con Docker + nginx proxy: dejar como /api (no cambiar)
VITE_API_URL=/api
